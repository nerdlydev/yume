{
  "name": "yume",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "bun run --filter @yume/database generate",
    "db:migrate": "bun run --filter @yume/database migrate",
    "db:push": "bun run --filter @yume/database push",
    "db:studio": "bun run --filter @yume/database studio",
    "db:seed": "bun run --filter @yume/database seed",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=@yume/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "husky": "^9.1.7",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.1.20"
}
